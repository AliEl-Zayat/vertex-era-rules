{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": ".",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"module": "ESNext",
		"target": "ES2022",
		"moduleResolution": "bundler",
		"removeComments": false,
		"noEmit": false,
		"skipLibCheck": true,
		"strict": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noFallthroughCasesInSwitch": true
	},
	"include": [
		"src/**/*.ts",
		"eslint-plugin-custom/**/*.ts",
		"configs/**/*.ts",
		"*.ts"
	],
	"exclude": [
		"**/*.test.ts",
		"**/*.spec.ts",
		"**/__tests__/**",
		"**/__mocks__/**",
		"node_modules",
		"dist"
	]
}
